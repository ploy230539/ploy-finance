# Firebase web config — copy this file to ".env" and fill in your project's values.
# Get them from Firebase Console → Project settings → Your apps → SDK setup.
# Without these, the app runs on localStorage only (no login / no cloud sync).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
